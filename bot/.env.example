# bot/.env.example — 워크스페이스 전용. 루트 .env 가 우선이지만, bot 만 따로 운영할 때 사용.

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBAPP_URL=https://your-mini-app.vercel.app
BOT_SERVER_PORT=3000
NODE_ENV=development

