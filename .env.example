# Telegram Bot
# 봇파더(@BotFather)에서 발급받은 토큰
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Web App URL (프로덕션 배포 후 교체, 개발 중엔 https tunnel 주소)
# 개발: `npm run tunnel` 실행 후 출력되는 https://xxx.trycloudflare.com 값을 여기에.
# Telegram은 HTTPS만 허용하므로 http://localhost 로 두면 /start 의 WebApp 버튼이 생략됨.
TELEGRAM_WEBAPP_URL=http://localhost:5173

# Share ROI 바이럴 공유 카드가 참조하는 봇 핸들 (t.me/<VITE_BOT_USERNAME>).
# @BotFather 에서 확인. Vite 가 VITE_ 프리픽스만 프론트에 노출한다.
VITE_BOT_USERNAME=your_bot

# Bot API Server
BOT_SERVER_PORT=3000

# 환경 구분
NODE_ENV=development

# --- Supabase ---
# 프로젝트 대시보드 > Settings > API에서 복사
SUPABASE_URL=your_supabase_url_here
# anon/public key — RLS 적용됨, 클라이언트 노출 가능
SUPABASE_ANON_KEY=your_supabase_anon_key_here
# service_role key — RLS 우회, 백엔드(bot) 전용. 절대 클라이언트 노출 금지
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- Trading Engine ---
# Stage 6: USD 전환. 매일 지급되는 게임머니 = $100,000 (정수 달러 단위)
DAILY_ALLOWANCE=100000
# 시세 스트리밍 심볼 (쉼표 구분, 소문자) — 다중 코인 지원
MARKET_SYMBOLS=btcusdt,ethusdt,solusdt
