# Root .env.example — Trading Academy
# 복사 후 이름을 .env 로 변경. 모든 실제 값은 절대 커밋 금지.

# ─────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# 개발: cloudflared 터널 주소. 프로덕션: 실 배포 URL.
TELEGRAM_WEBAPP_URL=http://localhost:5173
# Share ROI 카드가 참조하는 봇 핸들 (t.me/<VITE_BOT_USERNAME>).
VITE_BOT_USERNAME=your_bot

# ─────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─────────────────────────────────────────
# Trading engine
# ─────────────────────────────────────────
DAILY_ALLOWANCE=100000
MARKET_SYMBOLS=btcusdt,ethusdt,solusdt

# ─────────────────────────────────────────
# Telegram groups
# ─────────────────────────────────────────
VIP_CHAT_ID=      # -1001234567890 형식. Elite Analyst 채팅방.
PREMIUM_CHAT_ID=  # InviteMember 가 관리하는 유료 채널 ID.

# ─────────────────────────────────────────
# Server / Ops
# ─────────────────────────────────────────
BOT_SERVER_PORT=3000
NODE_ENV=development
LOG_LEVEL=info
ADMIN_SECRET=generate-a-strong-random-string

# ─────────────────────────────────────────
# Observability (선택)
# ─────────────────────────────────────────
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─────────────────────────────────────────
# Analytics (선택) — 웹용
# ─────────────────────────────────────────
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ─────────────────────────────────────────
# Affiliates (B-11, B-12) — 두 가지 모드:
#   1) 수동 목록 — *_AFFILIATE_UIDS 쉼표 구분
#   2) 공식 API — KEY + SECRET
# ─────────────────────────────────────────
MEXC_AFFILIATE_UIDS=
MEXC_AFFILIATE_URL=
MEXC_API_KEY=
MEXC_API_SECRET=

BYBIT_AFFILIATE_UIDS=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ─────────────────────────────────────────
# Stage 15.2 — Premium Analytics
# ─────────────────────────────────────────
ANALYTICS_WINDOW_DAYS=30
ANALYTICS_CACHE_SECONDS=300

# ─────────────────────────────────────────
# Stage 15.2 — Premium Sync Cron
# ─────────────────────────────────────────
PREMIUM_SYNC_INTERVAL_MS=300000
PREMIUM_CHANNEL_ID=-1003913632127
RECHARGE_CHANNEL_ID=-1003764714164

# ─────────────────────────────────────────
# Stage 15.2 — Weekly Report
# ─────────────────────────────────────────
WEEKLY_REPORT_CRON="0 21 * * 0"
WEEKLY_REPORT_TZ=Asia/Seoul

# ─────────────────────────────────────────
# Stage 15.2 — Lock Mode
# ─────────────────────────────────────────
LOCK_MODE_DURATION_MINUTES=30

# ─────────────────────────────────────────
# Stage 15.2 — Initial Seed (replaces DAILY_ALLOWANCE)
# ─────────────────────────────────────────
INITIAL_SEED_USD=10000

